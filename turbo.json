{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["API_URL", "PORT", "DATABASE_URL", "JWT_SECRET", "ALLOWED_ORIGINS"]
    },
    "lint": {},
    "clean": {
      "cache": false
    }
  }
}